# =============================================================================
# TradeSense Backend (.env.example)
# =============================================================================
# Copy this file to .env and provide real credentials for non-placeholder values.
#
# ⚠️  FOR GITHUB ACTIONS CI/CD:
#   Keep local defaults for SQLite unless you explicitly run in Supabase mode.
#   If using Supabase in CI/CD, store credentials as GitHub Secrets:
#   - SUPABASE_URL
#   - SUPABASE_ANON_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
#   - SUPABASE_DB_URL
#   - REDIS_URL
# =============================================================================

# -----------------------------------------------------------------------------
# Core FastAPI settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
ENVIRONMENT=development

# Secrets (change for every environment)
SECRET_KEY=replace-with-32+character-secret
JWT_SECRET_KEY=replace-with-32+character-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
# Default: http://localhost:3000 (frontend), http://localhost:5173 (Vite dev), http://localhost:8080 (nginx)
# Production: Add your production domain(s) here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Local-first data backend
# -----------------------------------------------------------------------------
# sqlite (default): no external DB required
# supabase: enable Supabase/Postgres-backed runtime
DATA_BACKEND=sqlite
DB_PATH=backend/prices.db

# =============================================================================
# Supabase / Postgres (Store sensitive values as GitHub Secrets!)
# =============================================================================
# Local Supabase (when using docker-compose)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Production Supabase (uncomment and configure when using remote Supabase)
# IMPORTANT: Store these as GitHub Secrets for CI/CD pipelines!
# - SUPABASE_URL: Public API endpoint (safe to show)
# - SUPABASE_ANON_KEY: Read-only, safe but use SERVICE_ROLE_KEY for writes
# - SUPABASE_SERVICE_ROLE_KEY: Write access (PRIMARY credential - KEEP SECRET)
# - SUPABASE_DB_URL: Direct database connection (KEEP SECRET)
#
# GitHub Secrets setup:
#   1. Go to: Settings > Secrets and variables > Actions
#   2. Click "New repository secret"
#   3. Add each credential as a separate secret
#   4. Workflows will read from: ${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Supabase JWT configuration (for authentication)
# -----------------------------------------------------------------------------
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/keys
JWT_STORAGE_KEY=TradeSense_token

# -----------------------------------------------------------------------------
# Redis / Cache configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=TradeSense:api:
REDIS_TTL=3600
REDIS_CONNECT_TIMEOUT_SECONDS=1.0

# -----------------------------------------------------------------------------
# Celery task queue
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Data provider keys (supply at least one)
# -----------------------------------------------------------------------------
EODHD_API_KEY=
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINMARKETCAP_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Legacy alias still supported by backend config:
# BINANCE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
SENTRY_DSN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# =============================================================================
# AI/LLM AUDIT FRAMEWORK
# =============================================================================
# Enable/disable the AI audit system
AI_AUDIT_ENABLED=false

# LLM Provider Configuration
# Primary: OpenAI GPT-5 (extended context for codebase + DB analysis)
# Fallback: Perplexity (online RAG for real-time validation)
# Note: Anthropic removed - using GPT-5 + Perplexity for optimal reasoning
AI_AUDIT_PRIMARY_PROVIDER=openai
AI_AUDIT_FALLBACK_PROVIDER=perplexity

# OpenAI Configuration (GPT-5 with 128K context window)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=128000
OPENAI_TEMPERATURE=0.1

# BYOK router defaults (TradeSense.llm.LLMRouter)
ENABLE_EXTERNAL_LLM=false
LLM_PROVIDER=ollama  # rules | ollama | cpu | openai | anthropic
LLM_MODEL=llama3.2
LLM_TIMEOUT_SECONDS=30
SANITIZE_LLM_PAYLOADS=true
LLM_MAX_PROMPT_CHARS=20000
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_ML_BACKEND=numpy  # numpy | sklearn | onnx
LOCAL_ML_MODEL_PATH=

# Broker defaults (local-first)
BROKER_BACKEND=paper
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# Perplexity Configuration (Online RAG for validation)
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=llama-3.1-sonar-huge-128k-online
PERPLEXITY_MAX_TOKENS=127000
PERPLEXITY_TEMPERATURE=0.1

# Audit Configuration
AI_AUDIT_SCHEDULE=0 */6 * * *  # Run every 6 hours (cron format)
AI_AUDIT_REALTIME_LOGS=true    # Monitor logs in real-time
AI_AUDIT_DATA_SAMPLING_RATE=0.15  # Sample 15% of data for analysis
AI_AUDIT_MAX_CONTEXT_SIZE=250000  # Maximum tokens for context (250K)
AI_AUDIT_REPORT_FORMAT=json,markdown  # Output formats
AI_AUDIT_ALERT_THRESHOLD=high  # Alert on: low, medium, high, critical
AI_AUDIT_SLACK_WEBHOOK=  # Optional: Send alerts to Slack
AI_AUDIT_EMAIL_ALERTS=  # Optional: Comma-separated emails

# -----------------------------------------------------------------------------
# Application defaults
# -----------------------------------------------------------------------------
DEFAULT_LOOKBACK_DAYS=365
DEFAULT_MIN_HISTORY_DAYS=252
PRECOMPUTE_ENABLED=true
PRECOMPUTE_MAX_AGE_HOURS=6
PRECOMPUTE_MIN_CORRELATION=0.7
MODEL_VERSION=prod-v1
ENABLE_AUTO_POPULATE_ON_STARTUP=false

# -----------------------------------------------------------------------------
# Testing overrides (leave false in production)
# -----------------------------------------------------------------------------
TESTING=false
TEST_DATABASE_URL=sqlite:///test_TradeSense.db
TEST_REDIS_URL=redis://redis:6379/15
