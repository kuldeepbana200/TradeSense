# =============================================================================
# TradeSense FRONTEND - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy to .env.local and customize with your actual values
# Note: Only VITE_ prefixed variables are accessible in the browser

# =============================================================================
# 🚀 CORE APPLICATION SETTINGS
# =============================================================================
# Vite application configuration
VITE_APP_NAME="TradeSense"
VITE_APP_VERSION="2.0.0"
VITE_APP_DESCRIPTION="Enterprise Quantitative Trading Platform"
VITE_ENVIRONMENT=development

# =============================================================================
# 🌐 API BACKEND CONFIGURATION
# =============================================================================
# Backend API endpoint (adjust for your deployment)
VITE_API_BASE_URL=http://localhost:8000
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000

# WebSocket configuration
VITE_WS_BASE_URL=ws://localhost:8000
VITE_WS_RECONNECT_ATTEMPTS=5
VITE_WS_RECONNECT_DELAY=3000

# =============================================================================
# 🔐 AUTHENTICATION & SECURITY
# =============================================================================
# Authentication configuration
VITE_AUTH_ENABLED=true
VITE_JWT_STORAGE_KEY=TradeSense_token
VITE_REFRESH_TOKEN_KEY=TradeSense_refresh_token
VITE_TOKEN_REFRESH_THRESHOLD=300000

# Supabase (optional for frontend auth integration)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Session management
VITE_SESSION_TIMEOUT=1800000
VITE_AUTO_LOGOUT_ENABLED=true
VITE_REMEMBER_ME_ENABLED=true

# =============================================================================
# 📊 DATA & ANALYTICS CONFIGURATION
# =============================================================================
# Real-time data settings
VITE_REALTIME_UPDATES=true
VITE_UPDATE_INTERVAL=5000
VITE_MAX_RETRY_ATTEMPTS=3

# Chart and visualization settings
VITE_DEFAULT_CHART_TYPE=candlestick
VITE_MAX_DATA_POINTS=1000
VITE_CHART_ANIMATION_ENABLED=true
VITE_CHART_THEME=dark

# =============================================================================
# 💾 CACHING & PERFORMANCE
# =============================================================================
# Browser caching configuration
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=300000
VITE_OFFLINE_MODE_ENABLED=true

# Performance settings
VITE_LAZY_LOADING=true
VITE_VIRTUAL_SCROLLING=true
VITE_DEBOUNCE_DELAY=300

# =============================================================================
# 🎨 UI/UX CONFIGURATION
# =============================================================================
# Theme and appearance
VITE_DEFAULT_THEME=dark
VITE_THEME_PERSISTENCE=true
VITE_ANIMATIONS_ENABLED=true
VITE_REDUCED_MOTION_SUPPORT=true

# Layout preferences
VITE_SIDEBAR_DEFAULT_COLLAPSED=false
VITE_TABLE_PAGE_SIZE=50
VITE_NOTIFICATION_DURATION=5000

# =============================================================================
# 📈 TRADING & FINANCIAL SETTINGS
# =============================================================================
# Default analysis parameters
VITE_DEFAULT_LOOKBACK_DAYS=365
VITE_DEFAULT_CORRELATION_WINDOW=60
VITE_DEFAULT_CONFIDENCE_LEVEL=0.95

# Display preferences
VITE_CURRENCY_SYMBOL=$
VITE_DECIMAL_PLACES=4
VITE_PERCENTAGE_DECIMAL_PLACES=2
VITE_DATE_FORMAT=YYYY-MM-DD
VITE_TIME_FORMAT=HH:mm:ss

# =============================================================================
# 🔄 WEBSOCKET & REAL-TIME FEATURES
# =============================================================================
# WebSocket connection settings
VITE_ENABLE_WEBSOCKETS=true
VITE_WS_HEARTBEAT_INTERVAL=30000
VITE_WS_MAX_RECONNECT_ATTEMPTS=5

# Real-time data subscriptions
VITE_SUBSCRIBE_PRICE_UPDATES=true
VITE_SUBSCRIBE_CORRELATION_UPDATES=true
VITE_SUBSCRIBE_BACKTEST_PROGRESS=true

# =============================================================================
# 🧪 DEVELOPMENT & TESTING
# =============================================================================
# Development tools (only in development)
VITE_DEV_TOOLS_ENABLED=true
VITE_DEBUG_MODE=false
VITE_MOCK_API=false
VITE_CONSOLE_LOGGING=true

# Testing configuration
VITE_E2E_TESTING=false
VITE_PERFORMANCE_MONITORING=false

# =============================================================================
# 📊 ANALYTICS & MONITORING (Optional)
# =============================================================================
# User analytics (if enabled)
VITE_ANALYTICS_ENABLED=false
VITE_GOOGLE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=

# Error tracking
VITE_ERROR_TRACKING_ENABLED=false
VITE_SENTRY_DSN=

# Performance monitoring
VITE_PERFORMANCE_TRACKING=false
VITE_WEB_VITALS_ENABLED=true

# =============================================================================
# 🌍 INTERNATIONALIZATION
# =============================================================================
# Localization settings
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es,fr,de,ja,zh
VITE_LOCALE_PERSISTENCE=true
VITE_FALLBACK_LOCALE=en

# =============================================================================
# 🏷️ FEATURE FLAGS
# =============================================================================
# Feature toggles for gradual rollouts
VITE_FEATURE_CORRELATION_HEATMAP=true
VITE_FEATURE_PAIR_ANALYSIS=true
VITE_FEATURE_BACKTESTING=true
VITE_FEATURE_REAL_TIME_CHARTS=true
VITE_FEATURE_EXPORT_DATA=true
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_ADVANCED_FILTERS=true

# Experimental features (beta)
VITE_FEATURE_MACHINE_LEARNING=false
VITE_FEATURE_PORTFOLIO_OPTIMIZATION=false
VITE_FEATURE_OPTIONS_ANALYSIS=false

# =============================================================================
# 🔧 BUILD & DEPLOYMENT
# =============================================================================
# Build configuration (handled by Vite)
VITE_BUILD_SOURCE_MAPS=false
VITE_BUILD_MINIFY=true
VITE_PUBLIC_PATH=/

# CDN and static assets
VITE_CDN_URL=
VITE_STATIC_ASSETS_URL=

# =============================================================================
# 🌐 PRODUCTION SETTINGS
# =============================================================================
# Production API endpoints
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_WS_BASE_URL=wss://api.yourdomain.com

# Production security
# VITE_HTTPS_ONLY=true
# VITE_SECURE_COOKIES=true

# =============================================================================
# QUICK SETUP CHECKLIST:
# =============================================================================
# 1. ✅ Copy to .env.local (Vite convention)
# 2. ✅ Set VITE_API_BASE_URL to your backend URL
# 3. ✅ Configure VITE_WS_BASE_URL for WebSocket connection
# 4. ✅ Enable/disable features as needed
# 5. ✅ Run: npm run dev
# 
# Frontend Development Commands:
# - npm run dev     (start development server)
# - npm run build   (production build)  
# - npm run preview (preview production build)
# - npm run lint    (code linting)
#
# Note: Vite automatically loads .env.local in development
# For production, configure environment variables in your hosting platform
