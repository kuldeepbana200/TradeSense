# =============================================================================
# TradeSense Root Environment Configuration
# =============================================================================
# This file contains ONLY Docker Compose orchestration variables.
# Service-specific configuration goes in:
#   - backend/api/.env (all backend config, API keys, database)
#   - frontend-v2/.env (all VITE_* prefixed frontend config)
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Configure backend: cd backend/api && cp .env.example .env
# 3. Configure frontend: cd frontend-v2 && cp .env.example .env
# 4. Edit each .env file with your actual values
# =============================================================================

# Project metadata
COMPOSE_PROJECT_NAME=TradeSense

# Backend configuration file path
BACKEND_ENV_FILE=backend/api/.env
CELERY_ENV_FILE=backend/api/.env

# Frontend configuration file path
FRONTEND_ENV_FILE=frontend-v2/.env

# Redis settings (shared by containers)
# These can be overridden by backend/.env if needed
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# NOTE: Do NOT add API keys, database credentials, or secrets here!
# Those belong in backend/api/.env or frontend-v2/.env
# This file is for Docker Compose orchestration only.
# =============================================================================
# All Supabase, database, API key, and application config should be in:
#   - backend/api/.env (for backend services)
#   - frontend-v2/.env (for frontend services)
# =============================================================================
